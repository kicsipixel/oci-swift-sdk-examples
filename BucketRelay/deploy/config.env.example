# Copy this file to `config.env` and fill in your values, then run the deploy
# scripts in order. config.env is git-ignored so your OCIDs stay local.

# --- OCI CLI auth ---
export OCI_CLI_PROFILE="DEFAULT"        # profile in ~/.oci/config
# export OCI_CLI_AUTH="security_token"  # uncomment if this profile uses session-token auth

# --- Where to deploy ---
export COMPARTMENT_ID="ocid1.compartment.oc1..xxxxxxxx"   # compartment for all resources
export REGION="us-phoenix-1"            # region to deploy in
export HOME_REGION="us-phoenix-1"       # your tenancy's HOME region (IAM writes must go here)
export AVAILABILITY_DOMAIN="xxxx:PHX-AD-1"  # oci iam availability-domain list --compartment-id $COMPARTMENT_ID

# --- Container image (public registry so the instance can pull anonymously) ---
# A ready-to-use image is already published (arm64), so you can skip 2-build-and-push.sh
# and deploy straight away. To build your own, set this to your repo and run that script.
export IMAGE="docker.io/iliasaz/bucket-relay:latest"
export SHAPE="CI.Standard.A1.Flex"      # arm64. The published image is arm64; use A1.Flex.
                                        # For E4.Flex (x86), build your own with --platform linux/amd64.
export OCPUS="1"
export MEMORY_GBS="6"

# --- Names (safe defaults) ---
export PREFIX="bucket-relay"
export BUCKET="${PREFIX}-bucket"
export DG_NAME="${PREFIX}-dg"
export POLICY_NAME="${PREFIX}-policy"
